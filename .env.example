# IRAN DISCORD bot — local / self-host config
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# How often the full guild sync queue runs (default 5m)
SYNC_CYCLE_INTERVAL=5m

# Process one guild every N ms (avoid API bursts)
SYNC_GUILD_DELAY_MS=2500

# Skip writing if unchanged within this window
SYNC_DEBOUNCE=45s

# Member totals: public invite API only (no member pagination)
MEMBERS_FETCH_TIMEOUT=12s

# Member sync: one guild every N ms on startup (avoid gateway burst)
MEMBER_SYNC_DELAY_MS=5000

# Persist aggregate stats to data/bot_state.json
DATA_DIR=data
STATE_SAVE_INTERVAL=60s

# Log level: warn (default, minimal disk) | error | info | debug
LOG_LEVEL=warn

# Cosmetic sidebar presence
PRESENCE_ENABLED=true
PRESENCE_STATS_INTERVAL=30s
PRESENCE_ACTIVITY_TYPE=watching
